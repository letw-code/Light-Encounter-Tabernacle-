# Light Encounter Tabernacle - Backend Environment Configuration
# Copy this file to .env and update values as needed

# ===================
# Application
# ===================
DEBUG=True

# ===================
# Database (PostgreSQL)
# ===================
# PostgreSQL connection string format:
# postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/letw_db

# For SQLite development (uncomment below, comment above):
# DATABASE_URL=sqlite+aiosqlite:///./letw.db

# ===================
# JWT Authentication
# ===================
# IMPORTANT: Change this in production!
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===================
# Email Settings
# ===================
# Set EMAIL_ENABLED=True and configure SMTP to send real emails
EMAIL_ENABLED=False
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM_NAME=Light Encounter Tabernacle
EMAIL_FROM_ADDRESS=noreply@letw.org

# ===================
# Frontend URL
# ===================
# Used for generating verification links
FRONTEND_URL=http://localhost:3000
